## Private Studio
## Next.js app env vars

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional compatibility aliases (if reused utilities expect these names)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Server-only Supabase key for privileged operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic (required for triage/conversation APIs)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub OAuth (Supabase provider / app credentials)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
